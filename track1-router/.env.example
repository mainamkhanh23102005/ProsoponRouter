# Fill these from the official Participant Guide / Discord.
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=
FIREWORKS_API_KEY_ENV=FIREWORKS_API_KEY

# Comma-separated exact model IDs once confirmed.
ALLOWED_MODELS=
CHEAPEST_MODEL=

# Harness paths. Override only if the official harness differs.
TASK_INPUT_PATH=/input/tasks.json
RESULTS_OUTPUT_PATH=/output/results.json
RESULTS_SCHEMA_STYLE=list

# Use DRY_RUN=1 for local testing without API spend.
DRY_RUN=1
